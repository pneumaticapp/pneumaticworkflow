msgid "Token is expired."
msgstr "Le jeton a expiré."

msgid "Products list cannot be empty."
msgstr "La liste des produits ne peut pas être vide."

#, python-brace-format
msgid "Price with code(s) {code} not found."
msgstr "Prix avec le(s) code(s) {code} non trouvé."

msgid "Please, contact our support for a downgrade options."
msgstr "Veuillez contacter notre support pour des options de rétrogradation."

msgid "Subscription not exist."
msgstr "Abonnement inexistant."

msgid "Multiple subscriptions not allowed."
msgstr "Abonnements multiples non autorisés."

msgid "The request data does not change the subscription state."
msgstr "Les données de la demande ne modifient pas l'état de l'abonnement."

msgid "Current payment method is unavailable. Specify a new payment method to complete the action."
msgstr "Le mode de paiement actuel est indisponible. Veuillez spécifier un nouveau mode de paiement pour compléter l'action."

msgid "Payment failed. Check your payment method and balance or contact support."
msgstr "Paiement échoué. Vérifiez votre méthode de paiement et votre solde ou contactez le support."

msgid "You can only use your subscription's currency to make purchases."
msgstr "Vous ne pouvez utiliser que la devise de votre abonnement pour effectuer des achats."

#, python-brace-format
msgid "You cannot purchase more than {quantity} unit(s) of the \"{product}\" subscription."
msgstr "Vous ne pouvez pas acheter plus de {quantity} unité(s) de l'abonnement \"{product}\"."

#, python-brace-format
msgid "You cannot purchase less than {quantity} unit(s) of the \"{product}\" subscription."
msgstr "Vous ne pouvez pas acheter moins de {quantity} unité(s) de l'abonnement \"{product}\"."

#, python-brace-format
msgid "You cannot purchase more than {quantity} unit(s) of the \"{product}\"."
msgstr "Vous ne pouvez pas acheter plus de {quantity} unité(s) de \"{product}\"."

#, python-brace-format
msgid "You cannot purchase less than {quantity} unit(s) of the \"{product}\"."
msgstr "Vous ne pouvez pas acheter moins de {quantity} unité(s) de \"{product}\"."

msgid "Unsupported subscription plan."
msgstr "Plan d'abonnement non pris en charge."

msgid "Purchase at the archive price is disallowed."
msgstr "L'achat au prix d'archive est interdit."

msgid "No account found for this subscription."
msgstr "Aucun compte trouvé pour cet abonnement."

msgid "Billing is disabled, contact support to change the plan."
msgstr "La facturation est désactivée, contactez le support pour modifier le plan."

msgid "Webhook account not found."
msgstr "Compte Webhook non trouvé."

msgid "Webhook account owner not found."
msgstr "Propriétaire du compte Webhook introuvable."

msgid "Payments API is disabled in this project."
msgstr "L'API de paiements est désactivée dans ce projet."

msgid "Downgrade is not available while there is an active subscription."
msgstr "La rétrogradation n'est pas disponible tant qu'il y a un abonnement actif."

msgid "Account not found."
msgstr "Compte introuvable."

msgid "Master account not found for tenant."
msgstr "Compte principal introuvable pour le locataire."
