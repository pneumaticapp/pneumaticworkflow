msgid "Token is expired."
msgstr "Токен истек."

msgid "Products list cannot be empty."
msgstr "Список продуктов не может быть пустым."

#, python-brace-format
msgid "Price with code(s) {code} not found."
msgstr "Цена с кодом {code} не найдена."

msgid "Please, contact our support for a downgrade options."
msgstr "Пожалуйста, свяжитесь с нашей поддержкой для вариантов понижения тарифа."

msgid "Subscription not exist."
msgstr "Подписка не существует."

msgid "Multiple subscriptions not allowed."
msgstr "Несколько подписок не разрешены."

msgid "The request data does not change the subscription state."
msgstr "Данные запроса не изменяют состояние подписки."

msgid "Current payment method is unavailable. Specify a new payment method to complete the action."
msgstr "Текущий способ оплаты недоступен. Укажите новый способ оплаты, чтобы завершить действие."

msgid "Payment failed. Check your payment method and balance or contact support."
msgstr "Платеж не прошел. Проверьте ваш способ оплаты и баланс или свяжитесь со службой поддержки."

msgid "You can only use your subscription's currency to make purchases."
msgstr "Вы можете использовать только валюту вашей подписки для совершения покупок."

#, python-brace-format
msgid "You cannot purchase more than {quantity} unit(s) of the \"{product}\" subscription."
msgstr "Вы не можете приобрести более {quantity} единиц подписки \"{product}\"."

#, python-brace-format
msgid "You cannot purchase less than {quantity} unit(s) of the \"{product}\" subscription."
msgstr "Вы не можете приобрести менее {quantity} единиц подписки \"{product}\"."

#, python-brace-format
msgid "You cannot purchase more than {quantity} unit(s) of the \"{product}\"."
msgstr "Вы не можете приобрести более {quantity} единиц \"{product}\"."

#, python-brace-format
msgid "You cannot purchase less than {quantity} unit(s) of the \"{product}\"."
msgstr "Вы не можете приобрести менее {quantity} единиц \"{product}\"."

msgid "Unsupported subscription plan."
msgstr "Неподдерживаемый тарифный план подписки."

msgid "Purchase at the archive price is disallowed."
msgstr "Покупка по архивной цене запрещена."

msgid "No account found for this subscription."
msgstr "Аккаунт для этой подписки не найден."

msgid "Billing is disabled, contact support to change the plan."
msgstr "Биллинг отключен, свяжитесь со службой поддержки для изменения тарифного плана."

msgid "Webhook account not found."
msgstr "Аккаунт вебхука не найден."

msgid "Webhook account owner not found."
msgstr "Владелец аккаунт вебхука не найден"

msgid "Payments API is disabled in this project."
msgstr "Биллинг API отключено."

msgid "Downgrade is not available while there is an active subscription."
msgstr "Понижение тарифа недоступно при наличии активной подписки."

msgid "Account not found."
msgstr "Аккаунт не найден."

msgid "Master account not found for tenant."
msgstr "Мастер-аккаунт не найден для тенанта."
