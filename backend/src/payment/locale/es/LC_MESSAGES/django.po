msgid "Token is expired."
msgstr "El token ha expirado."

msgid "Products list cannot be empty."
msgstr "La lista de productos no puede estar vacía."

#, python-brace-format
msgid "Price with code(s) {code} not found."
msgstr "Precio con código(s) {code} no encontrado."

msgid "Please, contact our support for a downgrade options."
msgstr "Por favor, póngase en contacto con nuestro soporte para opciones de degradación."

msgid "Subscription not exist."
msgstr "Suscripción no existe."

msgid "Multiple subscriptions not allowed."
msgstr "Suscripciones múltiples no permitidas."

msgid "The request data does not change the subscription state."
msgstr "Los datos de la solicitud no cambian el estado de la suscripción."

msgid "Current payment method is unavailable. Specify a new payment method to complete the action."
msgstr "El método de pago actual no está disponible. Especifique un nuevo método de pago para completar la acción."

msgid "Payment failed. Check your payment method and balance or contact support."
msgstr "Pago fallido. Verifique su método de pago y saldo o contacte al soporte."

msgid "You can only use your subscription's currency to make purchases."
msgstr "Solo puedes usar la moneda de tu suscripción para realizar compras."

#, python-brace-format
msgid "You cannot purchase more than {quantity} unit(s) of the \"{product}\" subscription."
msgstr "No puede comprar más de {quantity} unidad(es) de la suscripción \"{product}\"."

#, python-brace-format
msgid "You cannot purchase less than {quantity} unit(s) of the \"{product}\" subscription."
msgstr "No puede comprar menos de {quantity} unidad(es) de la suscripción \"{product}\"."

#, python-brace-format
msgid "You cannot purchase more than {quantity} unit(s) of the \"{product}\"."
msgstr "No puede comprar más de {quantity} unidad(es) del \"{product}\"."

#, python-brace-format
msgid "You cannot purchase less than {quantity} unit(s) of the \"{product}\"."
msgstr "No puede comprar menos de {quantity} unidad(es) del \"{product}\"."

msgid "Unsupported subscription plan."
msgstr "Plan de suscripción no compatible."

msgid "Purchase at the archive price is disallowed."
msgstr "La compra al precio de archivo no está permitida."

msgid "No account found for this subscription."
msgstr "No se encontró ninguna cuenta para esta suscripción."

msgid "Billing is disabled, contact support to change the plan."
msgstr "La facturación está deshabilitada, contacte al soporte para cambiar el plan."

msgid "Webhook account not found."
msgstr "Cuenta de webhook no encontrada."

msgid "Webhook account owner not found."
msgstr "Propietario de la cuenta del webhook no encontrado."

msgid "Payments API is disabled in this project."
msgstr "La API de Pagos está deshabilitada en este proyecto."

msgid "Downgrade is not available while there is an active subscription."
msgstr "La degradación no está disponible mientras haya una suscripción activa."

msgid "Account not found."
msgstr "Cuenta no encontrada."

msgid "Master account not found for tenant."
msgstr "Cuenta maestra no encontrada para el inquilino."
