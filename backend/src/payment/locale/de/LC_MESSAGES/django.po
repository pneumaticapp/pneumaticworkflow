msgid "Token is expired."
msgstr "Token ist abgelaufen."

msgid "Products list cannot be empty."
msgstr "Die Produktliste darf nicht leer sein."

#, python-brace-format
msgid "Price with code(s) {code} not found."
msgstr "Preis mit Code(s) {code} nicht gefunden."

msgid "Please, contact our support for a downgrade options."
msgstr "Bitte kontaktieren Sie unseren Support für Downgrade-Optionen."

msgid "Subscription not exist."
msgstr "Abonnement existiert nicht."

msgid "Multiple subscriptions not allowed."
msgstr "Mehrfache Abonnements sind nicht erlaubt."

msgid "The request data does not change the subscription state."
msgstr "Die Anfragedaten ändern den Abonnementstatus nicht."

msgid "Current payment method is unavailable. Specify a new payment method to complete the action."
msgstr "Aktuelle Zahlungsmethode ist nicht verfügbar. Bitte geben Sie eine neue Zahlungsmethode an, um die Aktion abzuschließen."

msgid "Payment failed. Check your payment method and balance or contact support."
msgstr "Zahlung fehlgeschlagen. Überprüfen Sie Ihre Zahlungsmethode und Ihr Guthaben oder kontaktieren Sie den Support."

msgid "You can only use your subscription's currency to make purchases."
msgstr "Sie können nur die Währung Ihres Abonnements für Käufe verwenden."

#, python-brace-format
msgid "You cannot purchase more than {quantity} unit(s) of the \"{product}\" subscription."
msgstr "Sie können nicht mehr als {quantity} Einheit(en) des Abonnements \"{product}\" kaufen."

#, python-brace-format
msgid "You cannot purchase less than {quantity} unit(s) of the \"{product}\" subscription."
msgstr "Sie können nicht weniger als {quantity} Einheit(en) des \"{product}\" Abonnements kaufen."

#, python-brace-format
msgid "You cannot purchase more than {quantity} unit(s) of the \"{product}\"."
msgstr "Sie können nicht mehr als {quantity} Einheit(en) von \"{product}\" kaufen."

#, python-brace-format
msgid "You cannot purchase less than {quantity} unit(s) of the \"{product}\"."
msgstr "Sie können weniger als {quantity} Einheit(en) des \"{product}\" nicht kaufen."

msgid "Unsupported subscription plan."
msgstr "Nicht unterstützter Abonnementplan."

msgid "Purchase at the archive price is disallowed."
msgstr "Der Kauf zum Archivpreis ist nicht erlaubt."

msgid "No account found for this subscription."
msgstr "Kein Konto für dieses Abonnement gefunden."

msgid "Billing is disabled, contact support to change the plan."
msgstr "Die Abrechnung ist deaktiviert. Wenden Sie sich an den Support, um den Plan zu ändern."

msgid "Webhook account not found."
msgstr "Webhook-Konto nicht gefunden."

msgid "Webhook account owner not found."
msgstr "Webhook-Kontoinhaber nicht gefunden."

msgid "Payments API is disabled in this project."
msgstr "Zahlungs-API ist in diesem Projekt deaktiviert."

msgid "Downgrade is not available while there is an active subscription."
msgstr "Herabstufung ist nicht möglich, solange ein aktives Abonnement besteht."

msgid "Account not found."
msgstr "Konto nicht gefunden."

msgid "Master account not found for tenant."
msgstr "Hauptkonto für Mieter nicht gefunden."
