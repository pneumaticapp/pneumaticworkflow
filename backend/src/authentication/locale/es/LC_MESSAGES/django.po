msgid "Access token not found for the user."
msgstr "Token de acceso no encontrado para el usuario."

#, python-brace-format
msgid "Your account has not been verified. A new verification link was sent to {email}."
msgstr "Su cuenta no ha sido verificada. Se ha enviado un nuevo enlace de verificación a {email}."

msgid "Invalid login or password."
msgstr "Inicio de sesión o contraseña no válidos."

#. Translators: Microsoft account doesn't contain email
msgid "Email is not listed in profile."
msgstr "El correo electrónico no está listado en el perfil."

msgid "Error while retrieving Microsoft profile data."
msgstr "Error al recuperar los datos del perfil de Microsoft."

msgid "Phone number must be entered in the format: \"+99999999999\". Up to 15 digits allowed."
msgstr "El número de teléfono debe ingresarse en el formato: \"+99999999999\". Se permiten hasta 15 dígitos."

#. Translators: Guest authentication
msgid "Authorization header contain spaces."
msgstr "El encabezado de autorización contiene espacios."

msgid "Token is invalid."
msgstr "El token no es válido."

msgid "Token is expired."
msgstr "El token ha expirado."

#. Translators: Guest authentication
msgid "Given token not valid for guest token type."
msgstr "El token proporcionado no es válido para el tipo de token de invitado."

#. Translators: Guest authentication
msgid "Token contained no recognizable user identification."
msgstr "El token no contiene una identificación de usuario reconocible."

#. Translators: Change password from profile
msgid "The current password is incorrect."
msgstr "La contraseña actual es incorrecta."

msgid "The new password and its confirmation don't match."
msgstr "La nueva contraseña y su confirmación no coinciden."

#. Translators: Google authorization
#, fuzzy
#| msgid "Error while retrieving Microsoft profile data."
msgid "Error while retrieving Google profile data."
msgstr "Error al recuperar los datos del perfil de Microsoft."

msgid "The system is configured to use a different SSO provider. Please contact your administrator."
msgstr "El sistema está configurado para usar otro proveedor de SSO. Por favor, contacte a su administrador."

msgid "This account uses SSO authentication. Please sign in through your organization's SSO portal."
msgstr "Esta cuenta utiliza autenticación SSO. Por favor, inicie sesión a través del portal SSO de su organización."

msgid "SSO authentication is currently unavailable. Please contact support."
msgstr "La autenticación SSO no está disponible en este momento. Por favor, contacte con soporte."

#, python-brace-format
msgid "No active SSO configuration found for the domain: \"{domain}\"."
msgstr "No se encontró una configuración SSO activa para el dominio: \"{domain}\"."

msgid "This account does not use SSO authentication. Please contact support."
msgstr "Esta cuenta no utiliza autenticación SSO. Por favor, contacte con soporte."

msgid "Format field is required"
msgstr ""
